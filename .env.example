DEEPSEEK_API_KEY=
CHEAP_LLM_MODEL=deepseek-v4-flash

# --- In-page editor (/editor route) — Cloudflare Pages Functions env vars ---
# Set these in Cloudflare Pages > Settings > Environment variables (Production):
# EDIT_PASSCODE   – the passcode you type in the editor (the "验证码")
# GITHUB_PAT      – a GitHub Personal Access Token with repo scope (writes back to the repo via the editor's save-all batch commit)
# GITHUB_REPO     – optional, defaults to hanknife/atelier-modulus-website
#
# Image uploads go to Cloudflare R2 (instant URL, no rebuild wait):
#   EDITOR_BUCKET  – R2 bucket binding, added in Cloudflare Pages > Settings > Bindings (pick the bucket, name it EDITOR_BUCKET)
#   R2_PUBLIC_URL  – the bucket's public access URL, e.g. https://pub-xxxx.r2.dev
#
# Note: EDITOR_BUCKET is a *binding*, not a plain env var — add it under
# Settings > Functions > R2 bucket bindings, not under "Environment variables".

