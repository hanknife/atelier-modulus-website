DEEPSEEK_API_KEY=
CHEAP_LLM_MODEL=deepseek-v4-flash

# --- In-page editor (/editor route) — Cloudflare Pages Functions env vars ---
# Set these in Cloudflare Pages > Settings > Environment variables (Production):
# EDIT_PASSCODE   – the passcode you type in the editor (the "验证码")
# GITHUB_PAT      – a GitHub Personal Access Token with repo scope (writes back to the repo)
# GITHUB_REPO     – optional, defaults to hanknife/atelier-modulus-website

