---
import "../styles/global.css";
import { getCollection } from "astro:content";

const {
  title = "Atelier Modulus",
  description = "A quiet architecture studio portfolio built as a static site.",
  bodyClass = "",
  footerLeftLabel = "COUPLING",
  footerLeftHref = "/coupling/",
  footerLeftToggle = "",
  closeHref = "",
  closeText = "→Close",
  brandLabel = "ATELIER MODULUS",
  showInfo = true
} = Astro.props;

const allProjects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);

// Projects 菜单：按 list_title 前三位数字升序排列（000 → 032）。
// 与编辑器内的排序保持一致，使新增的 "000 New Project" 出现在最顶部。
const projectList = allProjects
  .filter((p) => p.data.category === "projects")
  .sort((a, b) =>
    String(a.data.list_title ?? a.data.title).localeCompare(
      String(b.data.list_title ?? b.data.title)
    )
  );
// Lehrgerüste 菜单：按 order 升序（与主页从上到下位置一致）
const lehrgeruesteList = allProjects
  .filter((p) => p.data.category === "lehrgerueste")
  .sort((a, b) => a.data.order - b.data.order);

const info = (await getCollection("info")).find((i) => i.id.replace(/\.mdx?$/, "") === "info");
const infoData = info?.data;
const infoFrontmatter = info ? JSON.stringify({ ...infoData, __body: info.body ?? "" }) : "{}";

// Absolute leading/trailing-whitespace guard for Info text. Trims every line
// (not just the whole string) so any stray indentation in the source markdown
// can never surface as a visible leading space in the rendered overlay/page.
const cleanLines = (v: unknown): string =>
  String(v ?? "")
    .split("\n")
    .map((l) => l.trim())
    .join("\n")
    .trim();

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class={bodyClass}>
    <header class="site-header">
      <nav class="nav nav-top" aria-label="Primary navigation">
        <a class="link-blue nav-left" href="/projects/" data-overlay-toggle="projects">PROJECTS</a>
        <span class="nav-center">
          {closeHref && <a class="close-link" href={closeHref}>{closeText}</a>}
          <a class="brand" href="/" aria-label="Atelier Modulus home">{brandLabel}</a>
        </span>
        <a class="link-blue nav-right" href="/lehrgerueste/" data-overlay-toggle="lehrgerueste">LEHRGERÜSTE</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <aside class="half-overlay overlay-left project-overlay" id="projects-overlay" aria-label="Projects index" hidden>
      <nav>
        {projectList.map((project) => {
          const slug = project.id.replace(/\.mdx?$/, "");
          return (
            <a href={`/?open=${slug}&side=left`} data-detail-slug={slug} data-detail-side="left">
              {project.data.list_title ?? project.data.title}
            </a>
          );
        })}
      </nav>
    </aside>
    <aside class="half-overlay overlay-right lehr-overlay" id="lehrgerueste-overlay" aria-label="Lehrgerüste index" hidden>
      <nav>
        {lehrgeruesteList.map((project) => {
          const slug = project.id.replace(/\.mdx?$/, "");
          return (
            <a href={`/?open=${slug}&side=right`} data-detail-slug={slug} data-detail-side="right">
              {project.data.list_title ?? project.data.title}
            </a>
          );
        })}
      </nav>
    </aside>
    <aside
      class="half-overlay overlay-right info-overlay"
      id="info-overlay"
      aria-label="Info"
      hidden
      data-info="true"
      data-path="src/content/info/info.md"
      data-frontmatter={infoFrontmatter}
    >
      {infoData && (
        <div class="info-overlay-content">
          <div class="info-grid-row">
            <div class="black-label info-address" data-edit="address" style="white-space: pre-wrap;">{cleanLines(infoData.address)}</div>
            <div class="black-label info-bio" data-edit="bio" style="white-space: pre-wrap;">{cleanLines(infoData.bio)}</div>
          </div>
          <div class="info-grid-row">
            <span class="black-label info-chip chip-exhibitions" data-edit="exhibitions_label">{cleanLines(infoData.exhibitions_label)}</span>
            <div class="black-label info-note" data-edit="exhibitions_note_html" data-edit-html="true" set:html={cleanLines(infoData.exhibitions_note_html)} />
          </div>
          <div class="info-grid-row">
            <span class="black-label info-chip chip-lectures" data-edit="lectures_label">{cleanLines(infoData.lectures_label)}</span>
            <div class="black-label info-caption-lecture" data-edit="lectures_caption" style="white-space: pre-wrap;">{cleanLines(infoData.lectures_caption)}</div>
          </div>
          <div class="black-label info-caption" data-edit="footer_caption" style="white-space: pre-wrap;">{cleanLines(infoData.footer_caption)}</div>
        </div>
      )}
    </aside>
    <footer class="site-footer">
      <a
        class="link-green"
        href={footerLeftHref}
        data-filter-toggle={footerLeftToggle || undefined}
      >
        {footerLeftLabel}
      </a>
      {showInfo && <a href="/info/" data-overlay-toggle="info">INFO</a>}
    </footer>
    <script is:inline>
      const overlays = {
        projects: document.getElementById("projects-overlay"),
        lehrgerueste: document.getElementById("lehrgerueste-overlay"),
        info: document.getElementById("info-overlay")
      };

      const closeOverlaySide = (side) => {
        Object.values(overlays).forEach((overlay) => {
          if (!overlay) return;
          if (overlay.classList.contains(`overlay-${side}`)) overlay.hidden = true;
        });
      };

      document.addEventListener("click", (event) => {
        const toggle = event.target.closest("[data-overlay-toggle]");
        if (!toggle) return;
        const key = toggle.dataset.overlayToggle;
        const overlay = overlays[key];
        if (!overlay) return;
        event.preventDefault();
        const side = overlay.classList.contains("overlay-left") ? "left" : "right";
        const shouldOpen = overlay.hidden;
        closeOverlaySide(side);
        overlay.hidden = !shouldOpen;
      });

      document.addEventListener("click", (event) => {
        const toggle = event.target.closest("[data-filter-toggle]");
        if (!toggle) return;
        event.preventDefault();
        document.documentElement.classList.toggle("filter-open");
      });

      document.addEventListener("click", (event) => {
        const button = event.target.closest(".project-carousel");
        if (!button) return;
        const img = button.querySelector("img");
        if (!img) return;
        const images = JSON.parse(button.dataset.images || "[]");
        if (images.length < 2) return;
        const nextIndex = (Number(button.dataset.index || "0") + 1) % images.length;
        button.dataset.index = String(nextIndex);
        img.src = images[nextIndex];
      });
    </script>
    <script>
      import "../scripts/live-patch.ts";
    </script>
  </body>
</html>
