---
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);
---

{
  projects.map((project) => {
    const data = project.data;
    const slug = project.id.replace(/\.mdx?$/, "");
    const contentPath = `src/content/projects/${project.id}`;
    const body = project.body ?? "";
    const fm = JSON.stringify({ ...data, __body: body });
    const detailImages = [data.cover_image, ...data.gallery];
    const displayDate = data.display_date ?? String(data.year);
    const side = data.category === "lehrgerueste" ? "right" : "left";
    return (
      <aside
        class={`half-overlay overlay-${side} detail-overlay project-card project-detail`}
        id={`detail-overlay-${slug}`}
        data-slug={slug}
        data-path={contentPath}
        data-category={data.category}
        data-frontmatter={fm}
        hidden
        aria-label={`${data.title} details`}
      >
        <a
          href="#"
          class={`detail-nav-close detail-nav-close-${side} close-link`}
          data-detail-close="true"
        >
          {side === "right" ? "Close←" : "→Close"}
        </a>
        <header class="detail-title">
          <h1><span data-edit="title">{data.title}</span></h1>
          <p>
            <span data-edit="location">{data.location}</span><br />
            <span data-edit="type">{data.type}</span><br />
            <span data-edit="year">{displayDate}</span>
          </p>
        </header>
        <div class="detail-copy">
          <p><span data-edit="description_en">{data.description_en}</span></p>
        </div>
        <div class="detail-gallery" aria-label={`${data.title} gallery`}>
          {detailImages.map((image) => <img src={image} alt="" loading="lazy" />)}
        </div>
        <div class="edit-controls overlay-edit-strip" hidden>
          <label class="edit-add-gallery">
            添加图纸
            <input type="file" accept="image/*" data-role="add-gallery" multiple hidden />
          </label>
          <button type="button" data-role="delete-gallery">删除图纸</button>
        </div>
      </aside>
    );
  })
}

<script is:inline>
  const root = document.documentElement;

  function updateRootOverlayClasses() {
    var anyOpen = !!document.querySelector(".detail-overlay:not([hidden])");
    if (!anyOpen) {
      root.classList.remove(
        "detail-overlay-open",
        "detail-overlay-left",
        "detail-overlay-right"
      );
      return;
    }
    root.classList.add("detail-overlay-open");
    if (document.querySelector(".detail-overlay.overlay-left:not([hidden])")) {
      root.classList.add("detail-overlay-left");
    } else {
      root.classList.remove("detail-overlay-left");
    }
    if (document.querySelector(".detail-overlay.overlay-right:not([hidden])")) {
      root.classList.add("detail-overlay-right");
    } else {
      root.classList.remove("detail-overlay-right");
    }
  }

  function openDetailOverlay(slug, side) {
    var target = document.getElementById("detail-overlay-" + slug);
    if (!target) return;

    // Close any other overlay on the same side, keep the opposite side open.
    document.querySelectorAll(".detail-overlay.overlay-" + side).forEach(function (el) {
      el.hidden = el !== target;
    });

    updateRootOverlayClasses();
  }

  document.addEventListener("click", function (event) {
    var viewBtn = event.target.closest(".view-link");
    if (viewBtn) {
      event.preventDefault();
      var slug = viewBtn.dataset.slug;
      var side = viewBtn.dataset.side || "left";
      if (!slug) return;
      openDetailOverlay(slug, side);
      return;
    }

    var listLink = event.target.closest("[data-detail-slug]");
    if (listLink) {
      var slug = listLink.dataset.detailSlug;
      var side = listLink.dataset.detailSide || "left";
      var target = document.getElementById("detail-overlay-" + slug);
      if (!target) return;
      event.preventDefault();
      var listOverlay = listLink.closest(".project-overlay, .lehr-overlay");
      if (listOverlay) listOverlay.hidden = true;
      openDetailOverlay(slug, side);
      return;
    }

    var closeBtn = event.target.closest("[data-detail-close]");
    if (closeBtn) {
      event.preventDefault();
      var overlay = closeBtn.closest(".detail-overlay");
      if (overlay) {
        overlay.hidden = true;
        updateRootOverlayClasses();
      }
    }
  });

  document.addEventListener("DOMContentLoaded", function () {
    var params = new URLSearchParams(window.location.search);
    var openSlug = params.get("open");
    var openSide = params.get("side");
    if (openSlug) {
      openDetailOverlay(openSlug, openSide || "left");
    }
  });
</script>
