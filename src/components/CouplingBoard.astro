---
import type { CouplingImageMeta } from "../lib/coupling";

interface Props {
  items: CouplingImageMeta[];
  /** CSS class for the board container. Default "coupling-board" (grid collage).
   *  Pass "filter-board" for /filter/[term] pages (flex masonry). */
  boardClass?: string;
}

const { items, boardClass: bc = "coupling-board" } = Astro.props;

// Every source image shares a ~1.3 aspect ratio, so a by-ratio size mapping
// would make each tile the same width. Instead each tile gets an explicit
// column span from a fixed varied pattern so the wall reads as staggered
// (some wide, some narrow). The masonry script sizes each tile's row span
// from its rendered height so images keep their original aspect ratio.
const SIZE_PATTERN = [4, 3, 2, 3, 4, 2, 4, 3, 2, 3, 2, 4, 3, 2, 3, 2];
---

<section class={bc} aria-label="Coupling image board">
  {items.map(({ image, slug, side, isCover }, index) => {
    const size = SIZE_PATTERN[index % SIZE_PATTERN.length];
    return (
      <figure
        class={`coupling-tile tile-${index + 1} size-${size}`}
        data-size={size}
        data-detail-slug={slug}
        data-detail-side={side}
        data-detail-cover={isCover ? "cover" : undefined}
      >
        <img src={image} alt="" loading="eager" />
      </figure>
    );
  })}
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    var boards = document.querySelectorAll(".coupling-board, .filter-board");
    boards.forEach(function (board) {
      var tiles = Array.from(board.querySelectorAll(".coupling-tile"));
      // Fisher-Yates shuffle for visual variety
      for (var i = tiles.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var tmp = tiles[i];
        tiles[i] = tiles[j];
        tiles[j] = tmp;
      }
      tiles.forEach(function (tile, index) {
        var size = tile.dataset.size ? " size-" + tile.dataset.size : "";
        tile.className = "coupling-tile tile-" + (index + 1) + size;
        board.appendChild(tile);
      });
    });
    layoutGridMasonry();
    window.addEventListener("load", layoutGridMasonry);
    window.addEventListener("resize", layoutGridMasonry);
  });

  // Size each coupling-board (GRID) tile's row span from its rendered height.
  // Only applies to .coupling-board (the /coupling/ grid collage).
  // NOT needed for .filter-board (uses flex column-wrap masonry via CSS).
  function layoutGridMasonry() {
    var board = document.querySelector(".coupling-board");
    if (!board) return;
    var tiles = board.querySelectorAll(".coupling-tile");
    tiles.forEach(function (tile) {
      var img = tile.querySelector("img");
      if (!img) return;
      tile.style.gridRowEnd = "auto";
      var h = img.getBoundingClientRect().height;
      if (!h) {
        img.addEventListener("load", layoutGridMasonry, { once: true });
        return;
      }
      var span = Math.ceil(h) + 20;
      tile.style.gridRowEnd = "span " + span;
    });
  }
</script>
