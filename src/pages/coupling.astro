---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectDetailOverlays from "../components/ProjectDetailOverlays.astro";
import CouplingFilterStrip from "../components/CouplingFilterStrip.astro";
import CouplingBoard from "../components/CouplingBoard.astro";

const boardImages = [
  "/images/project-1-1.jpg",
  "/images/project-1-2.jpg",
  "/images/project-1-3.jpg",
  "/images/project-2-1.jpg",
  "/images/project-2-2.jpg",
  "/images/project-2-3.jpg",
  "/images/project-3-1.jpg",
  "/images/project-3-2.jpg",
  "/images/project-3-3.jpg",
  "/images/cargo-p-delta.png",
  "/images/cargo-p-delta-01.png",
  "/images/cargo-p-delta-02.png",
  "/images/cargo-p-delta-03.png",
  "/images/cargo-xiaobo.png",
  "/images/cargo-xiaobo-02.png",
  "/images/cargo-xiaobo-03.png"
];
---

<BaseLayout
  title="Coupling / Atelier Modulus"
  bodyClass="coupling-state"
  footerLeftLabel="FILTER"
  footerLeftHref="#filter"
  footerLeftToggle="filter"
>
  <ProjectDetailOverlays />
  <CouplingFilterStrip />
  <CouplingBoard images={boardImages} />
</BaseLayout>
