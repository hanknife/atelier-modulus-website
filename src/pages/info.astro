---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const info = (await getCollection("info")).find((i) => i.id.replace(/\.mdx?$/, "") === "info") ?? null;
const data = info?.data;
---

<BaseLayout title="Info / Atelier Modulus">
  <section class="info-collage" aria-label="Studio information">
    {data && (
      <>
        <img src={data.page_image} alt="" />
        <div class="black-label info-address" style="white-space: pre-wrap;">
          {data.address.trim()}
        </div>
        <div class="black-label info-bio" style="white-space: pre-wrap;">
          {data.bio.trim()}
        </div>
        <span class="black-label info-chip chip-exhibitions">{data.exhibitions_label.trim()}</span>
        <div class="black-label info-note" set:html={data.exhibitions_note_html.trim()} />
        <span class="black-label info-chip chip-lectures">{data.lectures_label.trim()}</span>
        <div class="black-label info-caption" style="white-space: pre-wrap;">
          {data.footer_caption.trim()}
        </div>
      </>
    )}
  </section>
</BaseLayout>
