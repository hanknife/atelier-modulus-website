---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order || b.data.year - a.data.year);

const leftProjects = projects.filter((_, index) => index % 2 === 0);
const rightProjects = projects.filter((_, index) => index % 2 === 1);
---

<BaseLayout>
  <section class="project-split home-index" aria-label="Project index">
    <div class="project-column" aria-label="Left project column">
      {leftProjects.map((project) => <ProjectCard project={project} side="left" />)}
    </div>
    <div class="project-column" aria-label="Right project column">
      {rightProjects.map((project) => <ProjectCard project={project} side="right" />)}
    </div>
  </section>

  {projects.map((project, index) => {
    const data = project.data;
    const slug = project.id.replace(/\.mdx?$/, "");
    const detailImages = [data.cover_image, ...data.gallery];
    const displayDate = data.display_date ?? String(data.year);
    const side = index % 2 === 0 ? "left" : "right";
    return (
      <aside class={`half-overlay overlay-${side} detail-overlay`} id={`detail-overlay-${slug}`} hidden aria-label={`${data.title} details`}>
        <header class="detail-title">
          <h1>{data.title}</h1>
          <p>
            {data.location}<br />
            {data.type}<br />
            {displayDate}
          </p>
        </header>
        <div class="detail-copy">
          <p>{data.description_en}</p>
        </div>
        <div class="detail-gallery" aria-label={`${data.title} gallery`}>
          {detailImages.map((image) => <img src={image} alt="" loading="lazy" />)}
        </div>
      </aside>
    );
  })}
</BaseLayout>

<script is:inline>
const root = document.documentElement;
const navLeft = document.querySelector(".nav-left");
const navRight = document.querySelector(".nav-right");
const navCenter = document.querySelector(".nav-center");
const brand = document.querySelector(".brand");
const detailClose = document.createElement("a");
detailClose.href = "#";
detailClose.className = "detail-nav-close close-link";
detailClose.dataset.detailClose = "true";

function closeDetailOverlays() {
  document.querySelectorAll(".detail-overlay").forEach(function(el) {
    el.hidden = true;
  });
  root.classList.remove("detail-overlay-open", "detail-overlay-left", "detail-overlay-right");
  if (navLeft) navLeft.hidden = false;
  if (navRight) navRight.hidden = false;
  if (brand) brand.textContent = "ATELIER MODULUS";
  detailClose.remove();
}

function openDetailOverlay(slug, side) {
  const target = document.getElementById("detail-overlay-" + slug);
  if (!target) return;

  document.querySelectorAll(".detail-overlay").forEach(function(el) {
    el.hidden = el !== target;
  });

  root.classList.remove("detail-overlay-left", "detail-overlay-right");
  root.classList.add("detail-overlay-open", "detail-overlay-" + side);

  if (side === "right") {
    if (navLeft) navLeft.hidden = false;
    if (navRight) navRight.hidden = true;
    if (brand) brand.textContent = "ATELIER";
    detailClose.textContent = "Close←";
    navCenter?.appendChild(detailClose);
  } else {
    if (navLeft) navLeft.hidden = true;
    if (navRight) navRight.hidden = false;
    if (brand) brand.textContent = "MODULUS";
    detailClose.textContent = "→Close";
    if (brand) {
      navCenter?.insertBefore(detailClose, brand);
    } else {
      navCenter?.appendChild(detailClose);
    }
  }
}

document.addEventListener("click", function(event) {
  var viewBtn = event.target.closest(".view-link");
  if (viewBtn) {
    event.preventDefault();
    var slug = viewBtn.dataset.slug;
    var side = viewBtn.dataset.side || "left";
    if (!slug) return;
    openDetailOverlay(slug, side);
    return;
  }

  var closeBtn = event.target.closest("[data-detail-close]");
  if (closeBtn) {
    event.preventDefault();
    closeDetailOverlays();
  }
});
</script>
