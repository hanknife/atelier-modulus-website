---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order || b.data.year - a.data.year);

const leftProjects = projects.filter((_, index) => index % 2 === 0);
const rightProjects = projects.filter((_, index) => index % 2 === 1);
---

<BaseLayout>
  <section class="project-split home-index" aria-label="Project index">
    <div class="project-column" aria-label="Left project column">
      {leftProjects.map((project) => <ProjectCard project={project} side="left" />)}
    </div>
    <div class="project-column" aria-label="Right project column">
      {rightProjects.map((project) => <ProjectCard project={project} side="right" />)}
    </div>
  </section>

  {projects.map((project, index) => {
    const data = project.data;
    const slug = project.id.replace(/\.mdx?$/, "");
    const detailImages = [data.cover_image, ...data.gallery];
    const displayDate = data.display_date ?? String(data.year);
    const side = index % 2 === 0 ? "left" : "right";
    return (
      <aside class={`half-overlay overlay-${side} detail-overlay`} id={`detail-overlay-${slug}`} hidden aria-label={`${data.title} details`}>
        <header class="detail-title">
          <h1>{data.title}</h1>
          <p>
            {data.location}<br />
            {data.type}<br />
            {displayDate}
          </p>
        </header>
        <div class="detail-copy">
          <p>{data.description_en}</p>
        </div>
        <div class="detail-gallery" aria-label={`${data.title} gallery`}>
          {detailImages.map((image) => <img src={image} alt="" loading="lazy" />)}
        </div>
      </aside>
    );
  })}
</BaseLayout>

<script is:inline>
document.addEventListener("click", function(event) {
  // View button clicked → open overlay on that side
  var viewBtn = event.target.closest(".view-link");
  if (viewBtn) {
    event.preventDefault();
    var slug = viewBtn.dataset.slug;
    if (!slug) return;

    // Find which side this project is on
    var card = viewBtn.closest(".project-card");
    var side = card && card.classList.contains("project-card-right") ? "right" : "left";

    // Hide all overlays, show target
    document.querySelectorAll(".detail-overlay").forEach(function(el) {
      el.hidden = (el.id !== "detail-overlay-" + slug);
    });

    // Update nav bar: inject close-link + adjust brand text
    var navCenter = document.querySelector(".nav-center");
    var brand = document.querySelector(".brand");
    if (navCenter && brand) {
      // Save original state on first open (idempotent)
      if (!navCenter.dataset._origBrand) {
        navCenter.dataset._origBrand = brand.textContent;
      }

      // Remove existing close-link if any
      var existing = navCenter.querySelector(".close-link-detail");
      if (existing) existing.remove();

      // Create close link
      var closeLink = document.createElement("a");
      closeLink.className = "close-link close-link-detail";
      closeLink.href = "#";
      closeLink.textContent = side === "right" ? "Close\u2190" : "\u2192Close";

      if (side === "right") {
        brand.textContent = "ATELIER";
        navCenter.appendChild(closeLink);
      } else {
        brand.textContent = "MODULUS";
        navCenter.insertBefore(closeLink, brand);
      }
    }
    return;
  }

  // Close link in nav → close overlay, restore nav
  var closeLink = event.target.closest(".close-link-detail");
  if (closeLink) {
    event.preventDefault();
    document.querySelectorAll(".detail-overlay").forEach(function(el) { el.hidden = true; });
    var navCenter = document.querySelector(".nav-center");
    var brand = document.querySelector(".brand");
    if (navCenter && brand) {
      var cl = navCenter.querySelector(".close-link-detail");
      if (cl) cl.remove();
      if (navCenter.dataset._origBrand) {
        brand.textContent = navCenter.dataset._origBrand;
      }
    }
  }
});
</script>
