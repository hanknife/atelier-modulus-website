---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ProjectDetailOverlays from "../components/ProjectDetailOverlays.astro";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);

const leftProjects = projects
  .filter((p) => p.data.category === "projects")
  .sort((a, b) => b.data.order - a.data.order);
const rightProjects = projects.filter((p) => p.data.category === "lehrgerueste");
---

<BaseLayout>
  <section class="project-split home-index" aria-label="Project index">
    <div class="project-column" aria-label="Left project column">
      {leftProjects.map((project) => <ProjectCard project={project} side="left" />)}
    </div>
    <div class="project-column" aria-label="Right project column">
      {rightProjects.map((project) => <ProjectCard project={project} side="right" />)}
    </div>
  </section>

  <ProjectDetailOverlays />
</BaseLayout>
