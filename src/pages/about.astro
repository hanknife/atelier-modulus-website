---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Info / Atelier Modulus">
  <section class="text-page">
    <h1>INFO</h1>
    <p>
      Atelier Modulus is an architecture and research practice focused on
      measured atmospheres, modest material systems, and long-life spatial
      strategies.
    </p>
    <p>
      The website is intentionally static and content-led. Projects are stored
      as Markdown entries, images live in public folders, and low-cost language
      processing is delegated to the DeepSeek helper script.
    </p>
  </section>
</BaseLayout>
